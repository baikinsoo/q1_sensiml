{
    "version": "1.8",
    "importedFrom": "firmware\\test_samd21.X",
    "configurations": [
        {
            "name": "default",
            "id": "conf1",
            "device": "ATSAMD21J18A",
            "imageType": "application",
            "imagePath": "./out/test_samd21/default.elf",
            "toolProperties": "default-tool",
            "tool": "EdbgTool",
            "packs": [
                {
                    "name": "SAMD21_DFP",
                    "vendor": "Microchip",
                    "version": "3.4.116"
                },
                {
                    "name": "CMSIS",
                    "vendor": "ARM",
                    "version": "5.4.0"
                }
            ],
            "fileSet": "Project files",
            "toolchain": "default-XC32"
        }
    ],
    "propertyGroups": [
        {
            "name": "default-XC32",
            "type": "toolchain",
            "provider": "microchip.toolchains:xc32@5.00",
            "properties": {
                "compiler.additional-warnings": true,
                "compiler.addresss-attribute-use": false,
                "compiler.enable-app-io": false,
                "compiler.enable-omit-frame-pointer": false,
                "compiler.enable-symbols": true,
                "compiler.enable-unroll-loops": false,
                "compiler.exclude-floating-point": false,
                "compiler.extra-include-directories": "firmware/src;firmware/src/config/default;firmware/src/packs/ATSAMD21J18A_DFP;firmware/src/packs/CMSIS;firmware/src/packs/CMSIS/CMSIS/Core/Include;firmware/test_samd21.X",
                "compiler.generate-16-bit-code": false,
                "compiler.generate-micro-compressed-code": false,
                "compiler.isolate-each-function": true,
                "compiler.make-warnings-into-errors": true,
                "compiler.optimization-level": "-O1",
                "compiler.place-data-into-section": true,
                "compiler.post-instruction-scheduling": "default",
                "compiler.pre-instruction-scheduling": "default",
                "compiler.strict-ansi": false,
                "compiler.support-ansi": false,
                "compiler.use-cci": false,
                "compiler.use-iar": false,
                "compiler.use-indirect-calls": false,
                "compiler++.additional-warnings": false,
                "compiler++.addresss-attribute-use": false,
                "compiler++.check-new": false,
                "compiler++.eh-specs": true,
                "compiler++.enable-app-io": false,
                "compiler++.enable-omit-frame-pointer": false,
                "compiler++.enable-symbols": true,
                "compiler++.enable-unroll-loops": false,
                "compiler++.exceptions": true,
                "compiler++.exclude-floating-point": false,
                "compiler++.extra-include-directories": "firmware/src;firmware/src/config/default;firmware/src/packs/ATSAMD21J18A_DFP;firmware/src/packs/CMSIS;firmware/src/packs/CMSIS/CMSIS/Core/Include;firmware/test_samd21.X",
                "compiler++.generate-16-bit-code": false,
                "compiler++.generate-micro-compressed-code": false,
                "compiler++.isolate-each-function": true,
                "compiler++.make-warnings-into-errors": false,
                "compiler++.optimization-level": "-O1",
                "compiler++.place-data-into-section": false,
                "compiler++.post-instruction-scheduling": "default",
                "compiler++.pre-instruction-scheduling": "default",
                "compiler++.rtti": true,
                "compiler++.strict-ansi": false,
                "compiler++.use-cci": false,
                "compiler++.use-iar": false,
                "compiler++.use-indirect-calls": false,
                "assembler.enable-symbols": true,
                "assembler.exclude-floating-point-library": false,
                "assembler.expand-macros": false,
                "assembler.extra-include-directories-for-assembler": "firmware/test_samd21.X",
                "assembler.extra-include-directories-for-preprocessor": "firmware/test_samd21.X",
                "assembler.false-conditionals": false,
                "assembler.generate-16-bit-code": false,
                "assembler.generate-micro-compressed-code": false,
                "assembler.keep-locals": false,
                "assembler.list-assembly": false,
                "assembler.list-source": false,
                "assembler.list-symbols": false,
                "assembler.oXC32asm-list-to-file": false,
                "assembler.omit-debug-dirs": false,
                "assembler.omit-forms": false,
                "archiver.additional-options-chop-files": false,
                "linker.additional-options-use-response-files": false,
                "linker.additional-options-write-sla": false,
                "linker.allocate-dinit": false,
                "linker.code-dinit": false,
                "linker.enable-check-sections": false,
                "linker.exclude-floating-point-library": false,
                "linker.exclude-standard-libraries": false,
                "linker.extra-lib-directories": "firmware/test_samd21.X",
                "linker.fill-flash-options-how": "0",
                "linker.fill-flash-options-inc-const": "1",
                "linker.fill-flash-options-what": "0",
                "linker.generate-16-bit-code": false,
                "linker.generate-cross-reference-file": false,
                "linker.generate-micro-compressed-code": false,
                "linker.heap-size": "512",
                "linker.no-device-startup-code": true,
                "linker.no-startup-files": false,
                "linker.remove-unused-sections": true,
                "linker.report-memory-usage": false,
                "linker.warn-section-align": false,
                "global.legacy-libc": false,
                "global.mstacktcm": false,
                "global.omit-pack-options": "1",
                "global.relaxed-math": false,
                "global.save-temps": false,
                "global.wpo-lto": false
            }
        },
        {
            "name": "default-tool",
            "type": "tool",
            "properties": {
                "AutoSelectMemRanges": "auto",
                "arm.use_vtor": false,
                "arm.vtor_adr": "exception_table",
                "communication.activationmode": "nohv",
                "communication.interface": "swd",
                "communication.speed": "2.000",
                "debugoptions.useswbreakpoints": false,
                "firmware.path": "Press to browse for a specific firmware version",
                "firmware.toolpack": "Press to select which tool pack to use",
                "firmware.update.action": "firmware.update.use.latest",
                "freeze.timers": false,
                "memories.aux": false,
                "memories.bootflash": true,
                "memories.configurationmemory": true,
                "memories.configurationmemory2": true,
                "memories.dataflash": true,
                "memories.eeprom": true,
                "memories.exclude.configurationmemory": true,
                "memories.flashdata": true,
                "memories.id": true,
                "memories.instruction.ram.ranges": "${memories.instruction.ram.ranges}",
                "memories.programmemory": true,
                "memories.programmemory.ranges": "0-3ffff",
                "memories.rww": true,
                "poweroptions.powerenable": false,
                "programoptions.eraseb4program": true,
                "programoptions.preservedataflash": false,
                "programoptions.preservedataflash.ranges": "${memories.dataflash.default}",
                "programoptions.preserveeeprom": false,
                "programoptions.preserveprogramrange": false,
                "programoptions.preserveuserid": false,
                "programoptions.programuserotp": false,
                "script.has_reset": true,
                "script.log_level": "1",
                "script.reset_delay": "0",
                "script.show_output": false,
                "toolpack.updateoptions": "toolpack.updateoptions.uselatestoolpack",
                "toolpack.updateoptions.packversion": "Press to select which tool pack to use",
                "x.erase.clearprot": true
            }
        }
    ],
    "fileSets": [
